/// 课程上课状态
enum ClassSessionState {
  /// 已排期（默认正常状态）
  SCHEDULED
  /// 已完成（正常上完）
  COMPLETED
  /// 学生请假
  LEAVE
  /// 该次取消（不补课）
  CANCELLED
  /// 调课（时间或日期变更）
  RESCHEDULED
}

/// 课程实例 — 由 ClassRule 生成，存储在数据库中
model ClassSession {
  /// 主键 ID（ULID）
  id String @id @default(ulid())

  /// 创建时间
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  /// 更新时间
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  /// 删除时间
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz()

  /// 所属规则 ID
  classRuleId String @map("class_rule_id")

  /// 所属课程 ID（冗余便于直接查询）
  courseId String @map("course_id")

  /// 该次上课的日期（规则生成的日期）
  occurrenceDate DateTime @map("occurrence_date") @db.Date

  /// 开始时间
  startTime DateTime @map("start_time") @db.Time()

  /// 结束时间
  endTime DateTime @map("end_time") @db.Time()

  /// 当前状态
  state ClassSessionState @default(SCHEDULED)

  /// 调课后的新日期（为空表示日期不变，仅时间调整）
  rescheduledDate DateTime? @map("rescheduled_date") @db.Date

  /// 调课后的新开始时间
  rescheduledStartTime DateTime? @map("rescheduled_start_time") @db.Time()

  /// 调课后的新结束时间
  rescheduledEndTime DateTime? @map("rescheduled_end_time") @db.Time()

  /// 原因说明
  reason String?

  /// 教室/场地
  room String?

  /// 所属规则
  classRule ClassRule @relation(fields: [classRuleId], references: [id], onDelete: Cascade)

  /// 所属课程
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  /// 参与该课程的学生
  participants SessionParticipant[]

  @@unique([classRuleId, occurrenceDate])
  @@index([classRuleId])
  @@index([courseId])
  @@index([occurrenceDate])
  @@map("class_session")
}
