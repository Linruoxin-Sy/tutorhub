/// 课程异常类型
enum ClassExceptionType {
  /// 请假
  LEAVE
  /// 调课（原课取消）
  RESCHEDULED
  /// 课程取消
  CANCELLED
  /// 已完成
  COMPLETED
}

model ClassException {
  /// 异常记录主键 ID（ULID）
  id String @id @default(ulid())

  /// 创建时间
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  /// 更新时间
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  /// 删除时间
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz()

  /// 所属规则 ID
  classRuleId String @map("class_rule_id")

  /// 发生日期
  occurrenceDate DateTime @map("occurrence_date") @db.Date

  /// 异常类型
  type ClassExceptionType

  /// 原因说明
  reason String?

  /// 所属规则
  classRule ClassRule @relation(fields: [classRuleId], references: [id], onDelete: Cascade)

  @@unique([classRuleId, occurrenceDate])
  @@index([classRuleId])
  @@index([occurrenceDate])
  @@map("class_exception")
}
