/// 课程上课状态（仅记录用户对 session 的变更）
enum ClassSessionOverrideState {
  /// 该次取消（不补课）
  CANCELLED
  /// 调课（时间或日期变更）
  RESCHEDULED
}

/// 课程实例变更记录 — 由 ClassRule 生成 session 后，用户对某个具体 session 的手动变更
model ClassSessionOverride {
  /// 主键 ID（ULID）
  id String @id @default(ulid())

  /// 创建时间
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  /// 更新时间
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  /// 所属规则 ID
  classRuleId String @map("class_rule_id")

  /// 原始上课日期（规则生成的日期，用于定位哪个 session 被修改）
  originalDate DateTime @map("original_date") @db.Date

  /// 变更类型
  state ClassSessionOverrideState

  /// 调课后的新日期（为空表示日期不变，仅时间调整）
  rescheduledDate DateTime? @map("rescheduled_date") @db.Date

  /// 调课后的新开始时间
  rescheduledStartTime DateTime? @map("rescheduled_start_time") @db.Time()

  /// 调课后的新结束时间
  rescheduledEndTime DateTime? @map("rescheduled_end_time") @db.Time()

  /// 原因说明
  reason String?

  /// 所属规则
  classRule ClassRule @relation(fields: [classRuleId], references: [id], onDelete: Cascade)

  @@unique([classRuleId, originalDate])
  @@index([classRuleId])
  @@index([originalDate])
  @@map("class_session_override")
}
