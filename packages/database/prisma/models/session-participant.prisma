/// 课程参与学生 — 表示某个学生参与了某次课程实例
model SessionParticipant {
  /// 主键 ID（ULID）
  id String @id @default(ulid())

  /// 创建时间
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  /// 更新时间
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  /// 删除时间
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz()

  /// 课程实例 ID
  classSessionId String @map("class_session_id")

  /// 学生 ID
  studentId String @map("student_id")

  /// 所属课程实例
  classSession ClassSession @relation(fields: [classSessionId], references: [id], onDelete: Cascade)

  /// 参与学生
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classSessionId, studentId])
  @@index([classSessionId])
  @@index([studentId])
  @@map("session_participant")
}
